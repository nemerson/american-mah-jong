{
  "name": "american-mah-jong",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "build": {
    "appId": "com.antigravity.mahjong",
    "asar": false,
    "win": {
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "package": "npm run build && electron-packager . american-mah-jong --platform=win32 --arch=x64 --out=release-builds --overwrite --no-asar --ignore=\"/src($|/)\" --ignore=\"/release-builds($|/)\" --ignore=\"/out($|/)\" --ignore=\"/\\.git($|/)\" --ignore=\"/\\.gitignore\""
  },
  "dependencies": {
    "framer-motion": "^12.35.0",
    "lodash": "^4.17.23",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}